@* Game Picker — portrait cover-flow carousel *@
@inject IJSRuntime JS

<div class="game-carousel">
    <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-4 text-center">Choose a game</p>

    <div class="game-carousel-viewport"
         @onpointerdown="OnPointerDown"
         @onpointermove="OnPointerMove"
         @onpointerup="OnPointerUp"
         @onpointercancel="OnPointerUp"
         @onpointerleave="OnPointerUp">
        <div class="game-carousel-track @(_dragging ? "is-dragging" : "")"
             style="transform: translateX(@($"{TrackOffsetPx:F1}px"))">
            @for (var i = 0; i < Games.Count; i++)
            {
                var game = Games[i];
                var index = i;
                var isActive = index == _focusedIndex;
                var distance = Math.Abs(index - _focusedIndex);

                if (game.SeparatorBefore)
                {
                    <div class="game-carousel-separator" aria-hidden="true">
                        <div class="game-carousel-separator-line"></div>
                        @if (!string.IsNullOrEmpty(game.SeparatorLabel))
                        {
                            <span class="game-carousel-separator-label">@game.SeparatorLabel</span>
                        }
                    </div>
                }

                var isLocked = LockedToGameId != null && game.Id != LockedToGameId;
                <button type="button"
                        @onclick="() => OnCardClick(index)"
                        class="game-carousel-card @(isActive ? "is-active" : "") @(game.ComingSoon || isLocked ? "is-disabled" : "") @(game.SinglePlayer ? "is-deck-card" : "")"
                        style="--distance: @distance"
                        aria-label="@game.Name"
                        aria-current="@(isActive ? "true" : null)"
                        disabled="@(isLocked)">
                    <div class="game-carousel-card-inner">
                        @if (!string.IsNullOrEmpty(game.ImageUrl))
                        {
                            <img src="@game.ImageUrl" alt="" class="game-carousel-image" loading="lazy" />
                        }
                        else
                        {
                            <div class="game-carousel-fallback game-carousel-fallback--@game.Id.ToLowerInvariant()">
                                <span class="game-carousel-icon">@game.Icon</span>
                            </div>
                        }
                        <div class="game-carousel-overlay"></div>
                        <div class="game-carousel-caption">
                            @if (string.IsNullOrEmpty(game.ImageUrl))
                            {
                                <div class="text-4xl mb-2 drop-shadow-lg">@game.Icon</div>
                            }
                            <div class="text-lg font-bold text-white leading-tight">@game.Name</div>
                            <div class="text-sm text-gray-300 mt-1">@game.Tagline</div>
                            @if (game.ComingSoon)
                            {
                                <div class="text-xs text-gray-400 mt-3 font-semibold uppercase tracking-wider">Coming soon</div>
                            }
                            else if (game.SinglePlayer)
                            {
                                <div class="text-xs text-emerald-300 mt-3 font-semibold uppercase tracking-wider">Deck card · External</div>
                            }
                            else if (game.Id == SelectedGameId)
                            {
                                <div class="text-xs text-yellow-400 mt-3 font-semibold uppercase tracking-wider">Selected</div>
                            }
                        </div>
                    </div>
                </button>
            }
        </div>
    </div>

    <div class="game-carousel-controls">
        <button type="button"
                class="game-carousel-nav"
                disabled="@(_focusedIndex == 0 || LockedToGameId != null)"
                @onclick="() => Shift(-1)"
                aria-label="Previous game">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:1.1em;height:1.1em;display:block"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="game-carousel-dots" role="tablist" aria-label="Games">
            @for (var i = 0; i < Games.Count; i++)
            {
                var index = i;
                if (Games[index].SeparatorBefore)
                {
                    <span class="game-carousel-dot-separator" aria-hidden="true"></span>
                }
                <button type="button"
                        role="tab"
                        class="game-carousel-dot @(index == _focusedIndex ? "is-active" : "") @(Games[index].SinglePlayer ? "is-deck-dot" : "")"
                        aria-selected="@(index == _focusedIndex)"
                        aria-label="@Games[index].Name"
                        disabled="@(LockedToGameId != null && Games[index].Id != LockedToGameId)"
                        @onclick="() => OnCardClick(index)">
                </button>
            }
        </div>
        <button type="button"
                class="game-carousel-nav"
                disabled="@(_focusedIndex >= Games.Count - 1 || LockedToGameId != null)"
                @onclick="() => Shift(1)"
                aria-label="Next game">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:1.1em;height:1.1em;display:block"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
    </div>
</div>

@code {
    public record GameOption(
        string Id,
        string Icon,
        string Name,
        string Tagline,
        string? ImageUrl = null,
        bool ComingSoon = false,
        bool SinglePlayer = false,
        string? ExternalUrl = null,
        bool SeparatorBefore = false,
        string? SeparatorLabel = null);

    [Parameter, EditorRequired] public IReadOnlyList<GameOption> Games { get; set; } = [];
    [Parameter] public string SelectedGameId { get; set; } = "";
    [Parameter] public EventCallback<string> SelectedGameIdChanged { get; set; }
    [Parameter] public string FocusedGameId { get; set; } = "";
    [Parameter] public EventCallback<string> FocusedGameIdChanged { get; set; }
    [Parameter] public EventCallback<string> OnTapped { get; set; }
    // When set, only this game ID is enabled; all others are visually disabled and non-selectable.
    [Parameter] public string? LockedToGameId { get; set; }

    private const double CardWidth = 280;
    private const double CardGap = 24;
    private const double SeparatorWidth = 52;

    private double _dragOffset;
    private bool _dragging;
    private bool _fromSwipe;
    private double _pointerStartX;
    private double _pointerStartY;
    private double _dragStartOffset;

    private int _focusedIndex;
    private int _primedIndex = -1;

    protected override void OnParametersSet()
    {
if (!string.IsNullOrEmpty(FocusedGameId))
        {
            var focused = Games.ToList().FindIndex(g => g.Id == FocusedGameId);
            if (focused >= 0)
                _focusedIndex = focused;
            return;
        }

        var selected = Games.ToList().FindIndex(g => g.Id == SelectedGameId);
        if (selected >= 0)
            _focusedIndex = selected;
    }

    private double TrackOffsetPx => -OffsetForIndex(_focusedIndex) + _dragOffset;

    private double OffsetForIndex(int index)
    {
        var offset = 0d;
        for (var i = 0; i < index; i++)
        {
            offset += CardWidth + CardGap;
            if (Games[i + 1].SeparatorBefore)
                offset += SeparatorWidth + CardGap;
        }

        return offset;
    }

    private async Task OnCardClick(int index)
    {
        if (index < 0 || index >= Games.Count) return;
        var game = Games[index];
        if (LockedToGameId != null && game.Id != LockedToGameId) return;

        bool wasAlreadyFocused = index == _focusedIndex;
        await JS.InvokeVoidAsync("gameInterop.playSound", "menu");
        await SetFocus(index);

        if (!game.ComingSoon && !game.SinglePlayer && game.Id != SelectedGameId)
        {
            SelectedGameId = game.Id;
            await SelectedGameIdChanged.InvokeAsync(game.Id);
        }

        // Swipes never navigate the page
        if (_fromSwipe) { _primedIndex = -1; return; }

        // Non-focused card: just focus it, reset primed state
        if (!wasAlreadyFocused) { _primedIndex = -1; return; }

        // Already focused: first click primes, second click navigates
        if (_primedIndex == index)
        {
            _primedIndex = -1;
            await OnTapped.InvokeAsync(game.Id);
        }
        else
        {
            _primedIndex = index;
        }
    }

    private async Task SetFocus(int index)
    {
        _focusedIndex = index;
        var id = Games[index].Id;
        if (FocusedGameId != id)
        {
            FocusedGameId = id;
            await FocusedGameIdChanged.InvokeAsync(id);
        }
    }

    // Arrows only change focus — never prime or navigate the page
    private async Task Shift(int delta)
    {
        var next = _focusedIndex + delta;
        if (next < 0 || next >= Games.Count) return;
        _primedIndex = -1;
        await JS.InvokeVoidAsync("gameInterop.playSound", "menu");
        await SetFocus(next);
        var game = Games[next];
        if (!game.ComingSoon && !game.SinglePlayer && game.Id != SelectedGameId)
        {
            SelectedGameId = game.Id;
            await SelectedGameIdChanged.InvokeAsync(game.Id);
        }
    }

    private void OnPointerDown(PointerEventArgs e)
    {
        _dragging = true;
        _pointerStartX = e.ClientX;
        _pointerStartY = e.ClientY;
        _dragStartOffset = _dragOffset;
        _fromSwipe = false;
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (!_dragging) return;
        var deltaX = e.ClientX - _pointerStartX;
        var deltaY = e.ClientY - _pointerStartY;
        // Only drag horizontally if the gesture is more horizontal than vertical
        if (Math.Abs(deltaX) > Math.Abs(deltaY))
            _dragOffset = _dragStartOffset + deltaX;
    }

    private async Task OnPointerUp(PointerEventArgs e)
    {
        if (!_dragging) return;
        _dragging = false;

        var deltaX = e.ClientX - _pointerStartX;
        var deltaY = e.ClientY - _pointerStartY;
        const double threshold = 48;

        // Vertical scroll: suppress click
        if (Math.Abs(deltaY) > Math.Abs(deltaX) && Math.Abs(deltaY) > 10)
        {
            _fromSwipe = true;
            _dragOffset = 0;
            return;
        }

        if (Math.Abs(deltaX) >= threshold)
        {
            _fromSwipe = true;
            await Shift(deltaX < 0 ? 1 : -1);
            _fromSwipe = false;
        }

        _dragOffset = 0;
    }
}
