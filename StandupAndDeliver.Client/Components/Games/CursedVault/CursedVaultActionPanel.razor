@if (!State.IsMyTurn)
{
    <div class="bg-gray-900/60 rounded-2xl p-5 md:p-8 border border-gray-800 flex items-center justify-center min-h-32 md:min-h-48 h-full">
        <p class="text-gray-500 text-sm md:text-base text-center">
            Waiting for <span class="text-white font-semibold">@State.CurrentPlayerName</span>…
        </p>
    </div>
    return;
}

@* ── Post-gamble: must play a card ── *@
@if (State.AwaitingMyCardPlay)
{
    <div class="bg-green-900/30 border border-green-700 rounded-2xl p-5 md:p-8 flex flex-col items-center gap-4 h-full justify-center">
        <p class="text-green-300 font-semibold text-sm md:text-base text-center">
            You collected <span class="text-yellow-400 font-bold">@State.ActiveGamble?.GoldCollectedSoFar gold</span>!
            Now play a card into the pile.
        </p>
        <div class="flex gap-4 md:gap-6">
            @if (State.MyGold > 0)
            {
                <button class="w-16 h-22 md:w-24 md:h-32 lg:w-28 lg:h-40 rounded-xl overflow-hidden ring-2 ring-yellow-400 hover:scale-105 transition-all shadow-lg cursor-pointer"
                        @onclick='() => OnPlayCardAfterGamble.InvokeAsync("Gold")'>
                    <img src="/games/cursed-vault/coin.webp" alt="Gold" class="w-full h-full object-cover" />
                </button>
            }
            @if (State.MyHasSkull)
            {
                <button class="w-16 h-22 md:w-24 md:h-32 lg:w-28 lg:h-40 rounded-xl overflow-hidden ring-2 ring-purple-500 hover:scale-105 transition-all shadow-lg cursor-pointer"
                        @onclick='() => OnPlayCardAfterGamble.InvokeAsync("Skull")'>
                    <img src="/games/cursed-vault/skull.webp" alt="Skull" class="w-full h-full object-cover" />
                </button>
            }
        </div>
        <p class="text-[10px] md:text-xs text-gray-500">Playing your skull is risky — others won't know it's in the pile</p>
    </div>
    return;
}

@* ── Mid-gamble: flip cards ── *@
@if (State.ActiveGamble is { } gamble)
{
    <div class="bg-yellow-900/20 border border-yellow-700/50 rounded-2xl p-5 md:p-8 flex flex-col items-center gap-4 h-full justify-center">
        <p class="text-yellow-300 text-sm md:text-base text-center">
            Flip @(gamble.FlipsSoFar + 1) of @gamble.Declared
            <span class="text-yellow-400 font-bold ml-2">(@gamble.GoldCollectedSoFar gold so far)</span>
        </p>
        <button class="px-10 py-4 md:px-14 md:py-5 bg-yellow-500 hover:bg-yellow-400 active:scale-95 text-black font-black rounded-2xl text-xl md:text-2xl transition-all shadow-lg cursor-pointer"
                @onclick="() => OnFlipCard.InvokeAsync()">
            🃏 Flip
        </button>
    </div>
    return;
}

@* ── Normal turn: play a card or gamble ── *@
<div class="bg-gray-900/60 rounded-2xl p-5 md:p-8 border border-gray-800 flex flex-col gap-5 h-full justify-center">
    @if (State.IsRoundOne)
    {
        <div class="text-center text-xs md:text-sm text-amber-400 bg-amber-900/20 border border-amber-700/40 rounded-xl px-4 py-2">
            Round 1 — Play a card to seed the pile. No gambling yet.
        </div>
    }

    <div class="flex gap-5 md:gap-8 justify-center items-start flex-wrap">

        @* Play a card *@
        <div class="flex flex-col items-center gap-3">
            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Play a card</p>
            <div class="flex gap-3 md:gap-4">
                @if (State.MyGold > 0)
                {
                    <button class="w-16 h-22 md:w-24 md:h-32 lg:w-28 lg:h-40 rounded-xl overflow-hidden ring-2 ring-yellow-600 hover:ring-yellow-400 hover:scale-110 hover:-translate-y-1 transition-all shadow-lg cursor-pointer"
                            @onclick='() => OnPlayCard.InvokeAsync("Gold")'
                            title="Play a Gold card into the pile">
                        <img src="/games/cursed-vault/coin.webp" alt="Gold" class="w-full h-full object-cover" />
                    </button>
                }
                @if (State.MyHasSkull)
                {
                    <button class="w-16 h-22 md:w-24 md:h-32 lg:w-28 lg:h-40 rounded-xl overflow-hidden ring-2 ring-purple-700 hover:ring-purple-400 hover:scale-110 hover:-translate-y-1 transition-all shadow-lg cursor-pointer"
                            @onclick='() => OnPlayCard.InvokeAsync("Skull")'
                            title="Play your Skull card — a trap for gamblers">
                        <img src="/games/cursed-vault/skull.webp" alt="Skull" class="w-full h-full object-cover" />
                    </button>
                }
            </div>
        </div>

        @if (!State.IsRoundOne && State.PileCount > 0)
        {
            <div class="flex flex-col items-center self-stretch justify-center">
                <div class="w-px h-full bg-gray-700 min-h-8"></div>
                <span class="text-gray-600 text-xs py-2">or</span>
                <div class="w-px h-full bg-gray-700 min-h-8"></div>
            </div>

            @* Gamble *@
            <div class="flex flex-col items-center gap-3">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Gamble</p>
                <div class="flex items-center gap-3 md:gap-4">
                    <button class="w-9 h-9 md:w-11 md:h-11 rounded-xl bg-gray-700 hover:bg-gray-600 text-white font-bold text-lg md:text-xl transition-all cursor-pointer disabled:opacity-30 disabled:cursor-not-allowed"
                            @onclick="DecrementGamble" disabled="@(_gambleCount <= 1)">−</button>
                    <span class="text-white font-bold text-2xl md:text-3xl w-8 text-center">@_gambleCount</span>
                    <button class="w-9 h-9 md:w-11 md:h-11 rounded-xl bg-gray-700 hover:bg-gray-600 text-white font-bold text-lg md:text-xl transition-all cursor-pointer disabled:opacity-30 disabled:cursor-not-allowed"
                            @onclick="IncrementGamble" disabled="@(_gambleCount >= State.PileCount)">+</button>
                </div>
                <p class="text-[10px] md:text-xs text-gray-600">of @State.PileCount cards</p>
                <button class="px-5 py-2.5 md:px-7 md:py-3 bg-purple-700 hover:bg-purple-600 active:scale-95 text-white font-bold rounded-xl transition-all shadow-lg cursor-pointer text-sm md:text-base"
                        @onclick="() => OnStartGamble.InvokeAsync(_gambleCount)">
                    ⚡ Gamble @_gambleCount
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public CursedVaultGameStateDto State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<string> OnPlayCard { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnStartGamble { get; set; }
    [Parameter, EditorRequired] public EventCallback OnFlipCard { get; set; }
    [Parameter, EditorRequired] public EventCallback<string> OnPlayCardAfterGamble { get; set; }

    private int _gambleCount = 1;

    private void IncrementGamble() { if (_gambleCount < State.PileCount) _gambleCount++; }
    private void DecrementGamble() { if (_gambleCount > 1) _gambleCount--; }
}
