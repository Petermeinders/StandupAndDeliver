@inject NavigationManager Nav
@inject GameStateService GameState
@inject SavedSessionService SavedSession

<div class="flex flex-col items-center gap-6 py-10 px-4">

    <div class="flex flex-col items-center gap-2">
        <span class="text-6xl">👑</span>
        <h2 class="text-3xl font-black text-yellow-400">@State.WinnerName wins!</h2>
        <p class="text-gray-400 text-sm">First to 10 gold — the vault is theirs</p>
    </div>

    <div class="w-full max-w-sm bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden">
        <div class="px-4 py-2 bg-gray-800/60 text-xs text-gray-500 uppercase tracking-widest font-semibold">
            Final standings
        </div>
        @foreach (var p in State.Players.OrderByDescending(p => p.Gold))
        {
            <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-800 last:border-0
                        @(p.Name == State.WinnerName ? "bg-yellow-400/10" : "")">
                <span class="text-lg @(p.Name == State.WinnerName ? "opacity-100" : "opacity-30")">
                    @(p.Name == State.WinnerName ? "👑" : p.IsEliminated ? "💀" : "")
                </span>
                <span class="flex-1 font-semibold @(p.IsEliminated ? "line-through text-gray-600" : p.Name == State.WinnerName ? "text-yellow-300" : "text-gray-300")">
                    @p.Name
                </span>
                <div class="flex items-center gap-1.5">
                    <img src="/games/cursed-vault/coin.webp" alt="" class="w-5 h-5 rounded object-cover" />
                    <span class="font-bold text-yellow-400">@p.Gold</span>
                </div>
            </div>
        }
    </div>

    <button @onclick="GoToMenu"
            class="mt-2 px-6 py-3 bg-gray-800 hover:bg-gray-700 active:scale-95 text-white font-semibold rounded-xl transition-all shadow-lg text-sm border border-gray-700">
        ← Back to Main Menu
    </button>

</div>

@code {
    [Parameter, EditorRequired] public CursedVaultGameStateDto State { get; set; } = default!;

    private async Task GoToMenu()
    {
        await SavedSession.ClearAsync();
        GameState.Clear();
        Nav.NavigateTo("/?game=cursed-vault");
    }
}
