@inject GameStateService GameState
@inject IJSRuntime JS

@{
    var gs = GameState.GetState<CursedVaultGameStateDto>("cursed-vault");
}

@if (gs is null)
{
    <div class="flex items-center justify-center h-64 text-gray-400">Loading Cursed Vault…</div>
    return;
}

@if (gs.Phase == "GameOver")
{
    <CursedVaultGameOver State="gs" />
    return;
}

<div class="flex flex-col min-h-screen gap-3 px-3 py-3 md:px-6 md:py-4 select-none max-w-screen-2xl mx-auto w-full">

    @* ── Header: Round + last turn + leave ── *@
    <div class="flex items-center justify-between text-xs text-gray-500 px-1 flex-shrink-0">
        <span class="uppercase tracking-widest font-semibold text-sm md:text-base text-gray-400">Round @gs.Round</span>
        @if (gs.LastTurnSummary is not null)
        {
            <CursedVaultLastTurn Summary="gs.LastTurnSummary" />
        }
        <LeaveGameButton />
    </div>

    @* ── Player ring — always at top, horizontal ── *@
    <CursedVaultPlayerList Players="gs.Players" />

    @* ── Desktop: pile + action side-by-side. Mobile: stacked. ── *@
    <div class="flex flex-col md:flex-row gap-3 md:gap-6 flex-1 items-start md:items-stretch justify-center">

        @* ── Center pile + flip feed ── *@
        <div class="flex flex-col items-center gap-3 flex-shrink-0 md:self-center">
            <CursedVaultPile PileCount="gs.PileCount" IsMyTurn="gs.IsMyTurn" PileShuffled="gs.PileShuffled" />
            @if (gs.ActiveGamble is not null)
            {
                <CursedVaultFlipFeed Gamble="gs.ActiveGamble" IsMyTurn="gs.IsMyTurn" />
            }
        </div>

        @* ── Action panel ── *@
        <div class="flex-1 md:max-w-md">
            <CursedVaultActionPanel
                State="gs"
                OnPlayCard="PlayCard"
                OnStartGamble="StartGamble"
                OnFlipCard="FlipCard"
                OnPlayCardAfterGamble="PlayCardAfterGamble" />
        </div>
    </div>

    @* ── Your hand — always at bottom ── *@
    <CursedVaultHand MyGold="gs.MyGold" MyHasSkull="gs.MyHasSkull" />

</div>

@code {
    [Parameter, EditorRequired] public Func<string, string?, Task<HubResult>> GameActionFunc { get; set; } = default!;

    private async Task PlayCard(string cardType)
    {
        await JS.InvokeVoidAsync("gameInterop.playSound", "click");
        await GameActionFunc("PlayCard", $"{{\"type\":\"{cardType}\"}}");
    }

    private async Task StartGamble(int count)
    {
        await JS.InvokeVoidAsync("gameInterop.playSound", "click");
        await GameActionFunc("StartGamble", $"{{\"count\":{count}}}");
    }

    private async Task FlipCard()
    {
        await JS.InvokeVoidAsync("gameInterop.playSound", "flip");
        await GameActionFunc("FlipCard", null);
    }

    private async Task PlayCardAfterGamble(string cardType)
    {
        await JS.InvokeVoidAsync("gameInterop.playSound", "click");
        await GameActionFunc("PlayCardAfterGamble", $"{{\"type\":\"{cardType}\"}}");
    }
}
