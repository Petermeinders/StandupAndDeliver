<div class="flex flex-col items-center gap-1">
    <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold">Central Pile</p>

    <div class="relative flex items-center justify-center w-24 h-32">
        @if (PileCount == 0)
        {
            <div class="w-20 h-28 rounded-xl border-2 border-dashed border-gray-700 flex items-center justify-center">
                <span class="text-gray-600 text-xs text-center leading-tight">Empty<br/>pile</span>
            </div>
        }
        else
        {
            @* Stacked card shadows — up to 4 offset layers *@
            @for (int i = Math.Min(PileCount - 1, 3); i >= 1; i--)
            {
                var offset = i;
                <div class="absolute w-20 h-28 rounded-xl overflow-hidden"
                     style="transform: translate(@(offset * 2)px, @(offset * -2)px); z-index: @(10 - offset)">
                    <img src="/games/cursed-vault/back.webp" alt="" class="w-full h-full object-cover" />
                </div>
            }
            @* Top card with pulse glow on your turn *@
            <div class="absolute w-20 h-28 rounded-xl overflow-hidden z-20
                        @(IsMyTurn && ActiveGamble is null ? "ring-2 ring-yellow-400 shadow-[0_0_16px_rgba(251,191,36,0.5)]" : "")">
                <img src="/games/cursed-vault/back.webp" alt="pile" class="w-full h-full object-cover" />
            </div>
        }
    </div>

    <span class="text-yellow-400 font-bold text-sm">@PileCount card@(PileCount != 1 ? "s" : "")</span>
</div>

@code {
    [Parameter, EditorRequired] public int PileCount { get; set; }
    [Parameter, EditorRequired] public bool IsMyTurn { get; set; }
    [Parameter] public ActiveGambleDto? ActiveGamble { get; set; }
}
