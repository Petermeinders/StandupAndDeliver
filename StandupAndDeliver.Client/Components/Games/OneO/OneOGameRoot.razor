@inject GameStateService GameState
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject SavedSessionService SavedSession

@{
    var oneOState = GameState.GetState<OneOGameStateDto>("OneO");
}

<div class="min-h-screen text-white flex flex-col p-4 max-w-2xl mx-auto">

    @if (oneOState is null)
    {
        <div class="flex items-center justify-center flex-1">
            <p class="text-gray-400">Waiting for game state…</p>
        </div>
    }
    else if (oneOState.Phase == "GameOver")
    {
        <div class="flex flex-col items-center justify-center flex-1 gap-6">
            <div class="text-6xl">🎉</div>
            <h2 class="text-3xl font-bold text-yellow-400">@oneOState.WinnerName wins!</h2>
            <p class="text-gray-400">Game over</p>
            <div class="bg-gray-900 rounded-2xl p-5 w-full max-w-sm">
                <h3 class="text-gray-400 text-sm font-semibold uppercase tracking-widest mb-3">Final Hand Counts</h3>
                @foreach (var kvp in oneOState.PlayerHandCounts.OrderBy(k => k.Value))
                {
                    <div class="flex justify-between py-1">
                        <span class="@(kvp.Key == oneOState.WinnerName ? "text-yellow-400 font-bold" : "text-gray-300")">@kvp.Key</span>
                        <span class="text-gray-500">@kvp.Value cards</span>
                    </div>
                }
            </div>
            <button @onclick="GoToMenu"
                    class="mt-2 px-6 py-3 bg-gray-800 hover:bg-gray-700 active:scale-95 text-white font-semibold rounded-xl transition-all shadow-lg text-sm border border-gray-700">
                ← Back to Main Menu
            </button>
        </div>
    }
    else
    {
        <div class="flex flex-col gap-4 flex-1">
            <div class="flex items-center justify-between">
                <span class="text-xs text-gray-500 font-mono">@oneOState.RoomCode</span>
                <span class="text-xs @(oneOState.Clockwise ? "text-blue-400" : "text-orange-400")">
                    @(oneOState.Clockwise ? "▶ Clockwise" : "◀ Counter-clockwise")
                </span>
                <LeaveGameButton />
            </div>

            <div class="flex gap-2 flex-wrap">
                @foreach (var player in oneOState.Players)
                {
                    var isCurrentPlayer = player.Name == oneOState.CurrentPlayerName;
                    var isMe = player.Name == GameState.PlayerName;
                    var count = oneOState.PlayerHandCounts.TryGetValue(player.Name, out var c) ? c : 0;
                    if (!isMe)
                    {
                        <div class="bg-gray-900 rounded-xl px-3 py-2 text-sm @(isCurrentPlayer ? "border border-yellow-400" : "border border-gray-700")">
                            <span class="@(isCurrentPlayer ? "text-yellow-400 font-bold" : "text-gray-400")">@player.Name</span>
                            <span class="text-gray-600 ml-2">@count cards</span>
                        </div>
                    }
                }
            </div>

            <OneOPlayArea GameActionFunc="GameActionFunc" />

            <OneOHand GameActionFunc="GameActionFunc" />

            @if (!string.IsNullOrEmpty(oneOState.LastAction))
            {
                <p class="text-center text-gray-500 text-sm italic">@oneOState.LastAction</p>
            }
        </div>
    }
</div>

@code {
    [Parameter] public required Func<string, string?, Task<HubResult>> GameActionFunc { get; set; }

    private bool _gameOverSoundPlayed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (GameState.GetState<OneOGameStateDto>("OneO")?.Phase == "GameOver" && !_gameOverSoundPlayed)
        {
            _gameOverSoundPlayed = true;
            await JS.InvokeVoidAsync("gameInterop.playSound", "levelup");
        }
    }

    private async Task GoToMenu()
    {
        await SavedSession.ClearAsync();
        GameState.Clear();
        Nav.NavigateTo("/?game=OneO");
    }
}
