@inject GameStateService GameState
@inject IJSRuntime JS

@{
    var oneOState = GameState.GetState<OneOGameStateDto>("OneO");
}

<div class="bg-gray-900/80 rounded-2xl p-3 md:p-5 border border-gray-800">
    <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-3">
        Your Hand <span class="text-gray-600">(@(oneOState?.MyHand.Count ?? 0) cards)</span>
    </p>

    @if (oneOState is null || oneOState.MyHand.Count == 0)
    {
        <p class="text-gray-600 text-sm text-center py-6">No cards</p>
    }
    else
    {
        @* On desktop fan cards with slight overlap for a hand feel *@
        <div class="flex flex-wrap md:flex-nowrap gap-1.5 md:gap-0 md:overflow-x-auto md:pb-2 items-end">
            @foreach (var card in oneOState.MyHand)
            {
                var canPlay = IsMyTurn && CanPlay(card, oneOState);
                <button @onclick="() => OnPlayCard(card)"
                        disabled="@(!canPlay)"
                        style="@CardBgStyle(card.Color)"
                        class="flex-shrink-0 w-16 h-24 md:w-20 md:h-28 lg:w-24 lg:h-36 rounded-xl border-2 flex flex-col items-center justify-center relative transition-all select-none md:-ml-3 first:ml-0
                               @CardBorderColor(card.Color)
                               @(canPlay
                                   ? "hover:scale-110 hover:-translate-y-3 hover:z-10 hover:shadow-xl cursor-pointer shadow-md"
                                   : "opacity-50 cursor-not-allowed")">
                    <span class="absolute top-1.5 left-2 text-[10px] md:text-xs font-black text-white leading-none drop-shadow-[0_1px_1px_rgba(0,0,0,0.8)]">@CardLabel(card)</span>
                    <span class="text-white text-2xl md:text-3xl lg:text-4xl font-black leading-none drop-shadow-[0_1px_2px_rgba(0,0,0,0.9)]">@CardLabel(card)</span>
                    <span class="absolute bottom-1.5 right-2 text-[10px] md:text-xs font-black text-white leading-none rotate-180 drop-shadow-[0_1px_1px_rgba(0,0,0,0.8)]">@CardLabel(card)</span>
                </button>
            }
        </div>
    }

    @if (_showColorPicker && _pendingWildCard is not null)
    {
        <div class="fixed inset-0 bg-black/70 flex items-center justify-center z-50">
            <div class="bg-gray-900 rounded-2xl p-8 flex flex-col items-center gap-5 border border-gray-700 shadow-2xl">
                <p class="text-white font-semibold text-lg">Choose a color</p>
                <div class="flex gap-5">
                    @foreach (var color in new[] { "Red", "Green", "Blue", "Yellow" })
                    {
                        <button @onclick="() => OnWildColorChosen(color)"
                                class="w-16 h-16 md:w-20 md:h-20 rounded-2xl hover:scale-110 transition-all shadow-lg @WildBtnColor(color)">
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public required Func<string, string?, Task<HubResult>> GameActionFunc { get; set; }

    private OneOCardDto? _pendingWildCard;
    private bool _showColorPicker;

    private bool IsMyTurn => GameState.GetState<OneOGameStateDto>("OneO")?.CurrentPlayerName == GameState.PlayerName;

    private static bool CanPlay(OneOCardDto card, OneOGameStateDto state)
    {
        if (state.TopDiscard is null) return false;
        if (card.Type is "Wild" or "WildDrawFour") return true;
        if (card.Color == state.CurrentColor) return true;
        var top = state.TopDiscard;
        if (card.Type == top.Type && card.Type != "Number") return true;
        if (card.Type == "Number" && top.Type == "Number" && card.Value == top.Value) return true;
        return false;
    }

    private async Task OnPlayCard(OneOCardDto card)
    {
        var state = GameState.GetState<OneOGameStateDto>("OneO");
        if (!IsMyTurn || state is null || !CanPlay(card, state)) return;

        if (card.Type is "Wild" or "WildDrawFour")
        {
            await JS.InvokeVoidAsync("gameInterop.playSound", "flip");
            _pendingWildCard = card;
            _showColorPicker = true;
            return;
        }

        await JS.InvokeVoidAsync("gameInterop.playSound", "flip");
        var payload = System.Text.Json.JsonSerializer.Serialize(new { cardId = card.Id });
        await GameActionFunc("PlayCard", payload);
    }

    private async Task OnWildColorChosen(string color)
    {
        _showColorPicker = false;
        await JS.InvokeVoidAsync("gameInterop.playSound", "spell");
        var payload = System.Text.Json.JsonSerializer.Serialize(new { cardId = _pendingWildCard!.Id, chosenColor = color });
        _pendingWildCard = null;
        await GameActionFunc("PlayCard", payload);
    }

    private static string CardLabel(OneOCardDto card) => card.Type switch
    {
        "Skip" => "⊘",
        "Reverse" => "⇄",
        "DrawTwo" => "+2",
        "Wild" => "★",
        "WildDrawFour" => "+4",
        _ => card.Value.ToString()
    };

    internal static string CardBgStyle(string color) => color switch
    {
        "Red"    => "border-image: url(/card-red.webp);    border-image-slice: 5 fill; border-image-width: 0px; border-image-outset: initial; border-image-repeat: round;",
        "Green"  => "border-image: url(/card-green.webp);  border-image-slice: 5 fill; border-image-width: 0px; border-image-outset: initial; border-image-repeat: round;",
        "Blue"   => "border-image: url(/card-blue.webp);   border-image-slice: 5 fill; border-image-width: 0px; border-image-outset: initial; border-image-repeat: round;",
        "Yellow" => "border-image: url(/card-yellow.webp); border-image-slice: 5 fill; border-image-width: 0px; border-image-outset: initial; border-image-repeat: round;",
        "Wild"   => "border-image: url(/card-wild.webp);   border-image-slice: 5 fill; border-image-width: 0px; border-image-outset: initial; border-image-repeat: round;",
        _        => "background-color: #374151;"
    };

    private static string CardBorderColor(string color) => color switch
    {
        "Red" => "border-red-400",
        "Green" => "border-green-400",
        "Blue" => "border-blue-400",
        "Yellow" => "border-yellow-300",
        "Wild" => "border-purple-400",
        _ => "border-gray-500"
    };

    private static string WildBtnColor(string color) => color switch
    {
        "Red" => "bg-red-500",
        "Green" => "bg-green-500",
        "Blue" => "bg-blue-500",
        "Yellow" => "bg-yellow-400",
        _ => "bg-gray-500"
    };
}
