@inject GameStateService GameState
@inject IJSRuntime JS

@{
    var oneOState = GameState.GetState<OneOGameStateDto>("OneO");
}

<div class="bg-gray-900/80 rounded-2xl p-5 md:p-8 flex flex-col items-center gap-5 md:gap-8 border border-gray-800">

    <div class="flex items-center gap-8 md:gap-16">

        @* ── Draw pile ── *@
        <div class="flex flex-col items-center gap-2 md:gap-3">
            <button @onclick="OnDrawCard"
                    disabled="@(!IsMyTurn)"
                    style="border-image: url(/card-deck.webp); border-image-slice: 5 fill; border-image-width: 0px; border-image-outset: initial; border-image-repeat: round;"
                    class="w-20 h-28 md:w-28 md:h-40 lg:w-32 lg:h-44 rounded-xl border-2 flex items-center justify-center text-2xl font-bold transition-all
                           @(IsMyTurn ? "border-blue-400 hover:scale-105 cursor-pointer shadow-[0_0_20px_rgba(96,165,250,0.3)]" : "border-gray-700 cursor-not-allowed opacity-60")">
            </button>
            <span class="text-xs md:text-sm text-gray-500">@(oneOState?.DrawPileCount ?? 0) left</span>
        </div>

        @* ── Discard pile ── *@
        <div class="flex flex-col items-center gap-2 md:gap-3">
            @if (oneOState?.TopDiscard is { } top)
            {
                <div class="w-20 h-28 md:w-28 md:h-40 lg:w-32 lg:h-44 rounded-xl border-2 flex flex-col items-center justify-center relative
                            @CardBorderColor(oneOState.CurrentColor)"
                     style="@OneOHand.CardBgStyle(top.Color)">
                    <span class="absolute top-1.5 left-2 text-[10px] md:text-xs font-bold text-white/70 leading-none">@CardLabel(top)</span>
                    <span class="text-3xl md:text-5xl font-black text-white drop-shadow">@CardLabel(top)</span>
                    <span class="absolute bottom-1.5 right-2 text-[10px] md:text-xs font-bold text-white/70 leading-none rotate-180">@CardLabel(top)</span>
                </div>
            }
            <span class="text-xs md:text-sm text-gray-500">
                Color: <span class="font-bold @ColorTextClass(oneOState?.CurrentColor ?? "")">@(oneOState?.CurrentColor ?? "")</span>
            </span>
        </div>
    </div>

    <div class="text-center">
        @if (IsMyTurn)
        {
            <p class="text-yellow-400 font-bold text-base md:text-lg">Your turn!</p>
        }
        else
        {
            <p class="text-gray-400 text-sm md:text-base">Waiting for <span class="text-white font-semibold">@(oneOState?.CurrentPlayerName)</span>…</p>
        }
    </div>
</div>

@code {
    [Parameter] public required Func<string, string?, Task<HubResult>> GameActionFunc { get; set; }

    private bool IsMyTurn => GameState.GetState<OneOGameStateDto>("OneO")?.CurrentPlayerName == GameState.PlayerName;

    private async Task OnDrawCard()
    {
        if (!IsMyTurn) return;
        await JS.InvokeVoidAsync("gameInterop.playSound", "flip");
        await GameActionFunc("DrawCard", null);
    }

    private static string CardLabel(OneOCardDto card) => card.Type switch
    {
        "Skip" => "⊘",
        "Reverse" => "⇄",
        "DrawTwo" => "+2",
        "Wild" => "★",
        "WildDrawFour" => "+4",
        _ => card.Value.ToString()
    };

    private static string CardBorderColor(string color) => color switch
    {
        "Red" => "border-red-500",
        "Green" => "border-green-500",
        "Blue" => "border-blue-500",
        "Yellow" => "border-yellow-400",
        _ => "border-gray-500"
    };

    private static string ColorTextClass(string color) => color switch
    {
        "Red" => "text-red-400",
        "Green" => "text-green-400",
        "Blue" => "text-blue-400",
        "Yellow" => "text-yellow-400",
        _ => "text-gray-400"
    };
}
