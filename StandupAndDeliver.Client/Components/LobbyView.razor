@inject GameStateService GameState

<div class="min-h-screen bg-gray-950 text-white flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md">

        <h1 class="text-3xl font-bold text-center mb-2">Standup & Deliver</h1>
        <p class="text-center text-gray-400 mb-8">Room code: <span class="font-mono font-bold text-yellow-400 text-2xl tracking-widest">@GameState.State!.RoomCode</span></p>

        <div class="bg-gray-900 rounded-2xl p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4 text-gray-300">Players (@GameState.State.Players.Count)</h2>
            <ul class="space-y-2">
                @foreach (var player in GameState.State.Players)
                {
                    <li class="flex items-center gap-3">
                        <span class="w-2 h-2 rounded-full @(player.IsConnected ? "bg-green-400" : "bg-gray-600")"></span>
                        <span class="@(player.IsConnected ? "text-white" : "text-gray-500")">@player.Name</span>
                        @if (player.IsHost)
                        {
                            <span class="text-xs bg-yellow-400 text-black px-2 py-0.5 rounded-full font-semibold ml-auto">HOST</span>
                        }
                    </li>
                }
            </ul>
        </div>

        @if (_isHost)
        {
            <div class="text-center">
                <button
                    @onclick="OnStartGame"
                    disabled="@_starting"
                    class="w-full py-4 rounded-xl font-bold text-lg transition-all bg-yellow-400 text-black hover:bg-yellow-300">
                    @(_starting ? "Starting…" : "Start Game")
                </button>
            </div>
        }
        else
        {
            <p class="text-center text-gray-400 text-sm">Waiting for the host to start the game…</p>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="mt-4 text-center text-red-400 text-sm">@_error</p>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EventCallback OnStart { get; set; }
    [Parameter, EditorRequired] public Func<Task<HubResult>> StartGameFunc { get; set; } = default!;

    private bool _isHost;
    private bool _starting;
    private string? _error;

    protected override void OnParametersSet()
    {
        _isHost = GameState.State?.Players
            .Any(p => p.Name == GameState.PlayerName && p.IsHost) ?? false;
    }

    private async Task OnStartGame()
    {
        _starting = true;
        _error = null;
        var result = await StartGameFunc();
        if (!result.Success) _error = result.Error;
        _starting = false;
    }
}
