@inject GameStateService GameState
@inject GameRegistry Registry
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject PlayerSettingsService PlayerSettings

@{
    var gameType = GameState.PlatformState?.GameType;
    var registration = gameType is not null ? Registry.Get(gameType) : null;
    var coverImage = registration?.ImageUrl;
    var gameTitle = registration?.Name ?? gameType ?? "Game";
}

<div class="min-h-screen text-white flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md">

        <div class="flex flex-col items-center mb-2">
            @if (!string.IsNullOrEmpty(coverImage))
            {
                <img src="@coverImage"
                     alt="@gameTitle deck cover"
                     class="w-20 h-[7.5rem] object-cover rounded-xl shadow-lg shadow-black/40 ring-1 ring-white/10 mb-3" />
            }
            <h1 class="text-3xl font-bold text-center">@gameTitle</h1>
        </div>
        <p class="text-center text-gray-400 mb-6">Room code: <span class="font-mono font-bold text-yellow-400 text-2xl tracking-widest">@GameState.PlatformState!.RoomCode</span></p>

        <div class="bg-gray-900 rounded-2xl p-5 mb-6 flex flex-col items-center gap-3">
            <p class="text-xs text-gray-400 uppercase tracking-widest">Scan to join</p>
            <img src="@QrCodeUrl" alt="QR code to join room" class="rounded-xl w-40 h-40" />
            <div class="flex items-center gap-2 w-full">
                <span class="flex-1 bg-gray-800 rounded-lg px-3 py-2 text-xs text-gray-400 font-mono truncate">@JoinUrl</span>
                <button @onclick="CopyJoinUrl" title="Copy link"
                        class="px-3 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 text-gray-300 text-xs transition-all">
                    @(_copied ? "✓" : "Copy")
                </button>
            </div>
        </div>

        <div class="bg-gray-900 rounded-2xl p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4 text-gray-300">Players (@GameState.PlatformState.Players.Count)</h2>
            <ul class="space-y-2">
                @foreach (var player in GameState.PlatformState.Players)
                {
                    <li class="flex items-center gap-3">
                        <span class="w-2 h-2 rounded-full @(player.IsConnected ? "bg-green-400" : "bg-gray-600")"></span>
                        <span class="@(player.IsConnected ? "text-white" : "text-gray-500")">@player.Name</span>
                        @if (player.IsHost)
                        {
                            <span class="text-xs bg-yellow-400 text-black px-2 py-0.5 rounded-full font-semibold ml-auto">HOST</span>
                        }
                    </li>
                }
            </ul>
        </div>

        @* ── Game Settings ── *@
        @if (gameType == "OneO")
        {
            <div class="bg-gray-900 rounded-2xl p-5 mb-6">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-3">Game Settings</h2>
                <label class="flex items-center justify-between gap-3 cursor-pointer">
                    <span class="text-white text-sm font-medium">Numbers Only</span>
                    <input type="checkbox"
                           checked="@PlayerSettings.OneONumbersOnly"
                           @onchange="OnNumbersOnlyChanged"
                           class="w-4 h-4 accent-yellow-400" />
                </label>
                <p class="text-xs text-gray-500 mt-1.5">Remove all special cards (Skip, Reverse, Draw Two, Wilds) for a simpler game.</p>
            </div>
        }

        @if (_isHost)
        {
            <div class="text-center">
                <button
                    @onclick="OnStartGame"
                    disabled="@_starting"
                    class="w-full py-4 rounded-xl font-bold text-lg transition-all bg-yellow-400 text-black hover:bg-yellow-300">
                    @(_starting ? "Starting…" : "Start Game")
                </button>
            </div>
        }
        else
        {
            <p class="text-center text-gray-400 text-sm">Waiting for the host to start the game…</p>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="mt-4 text-center text-red-400 text-sm">@_error</p>
        }

        <div class="mt-6">
            <GameHowToPlay GameId="@(GameState.PlatformState?.GameType ?? "standup")" />
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EventCallback OnStart { get; set; }
    [Parameter, EditorRequired] public Func<string?, Task<HubResult>> StartGameFunc { get; set; } = default!;

    private bool _isHost;
    private bool _starting;
    private bool _copied;
    private string? _error;

    private string JoinUrl =>
        $"{Nav.BaseUri.TrimEnd('/')}?join={GameState.PlatformState?.RoomCode}";

    private string QrCodeUrl =>
        $"https://api.qrserver.com/v1/create-qr-code/?size=160x160&margin=10&data={Uri.EscapeDataString(JoinUrl)}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await PlayerSettings.LoadAsync();
    }

    protected override void OnParametersSet()
    {
        _isHost = GameState.PlatformState?.Players
            .Any(p => p.Name == GameState.PlayerName && p.IsHost) ?? false;
    }

    private async Task CopyJoinUrl()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", JoinUrl);
        _copied = true;
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }

    private async Task OnNumbersOnlyChanged(ChangeEventArgs e)
    {
        await PlayerSettings.SetOneONumbersOnlyAsync((bool)(e.Value ?? false));
    }

    private async Task OnStartGame()
    {
        _starting = true;
        _error = null;
        await JS.InvokeVoidAsync("gameInterop.playSound", "confirm");
        var gameType = GameState.PlatformState?.GameType;
        string? settingsJson = gameType switch
        {
            "OneO" => PlayerSettings.GetOneOSettingsJson(),
            _ => null
        };
        var result = await StartGameFunc(settingsJson);
        if (!result.Success) _error = result.Error;
        _starting = false;
    }
}
