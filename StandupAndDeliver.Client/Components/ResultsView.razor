@inject GameStateService GameState

<div class="min-h-screen text-white flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md">

        <p class="text-center text-gray-600 text-xs font-mono mb-4">Room: @GameState.State?.RoomCode</p>

        @{
            var result = GameState.State?.LastTurnResult;
        }

        <p class="text-center text-gray-400 text-xs uppercase tracking-widest mb-2">The prompt was…</p>

        <div class="bg-yellow-400 text-black rounded-2xl p-6 mb-6 text-center shadow-lg">
            <p class="text-lg font-bold leading-snug">@(result?.PromptCardText?.Split("|||")[0])</p>
        </div>

        @if (result is not null)
        {
            <div class="bg-gray-900 rounded-2xl p-6 mb-6 space-y-4">
                <div class="flex justify-between items-center">
                    <span class="text-gray-400 text-sm">Speaker</span>
                    <span class="font-semibold">@result.ActivePlayerName</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-gray-400 text-sm">Impressiveness</span>
                    <span class="font-semibold text-yellow-400">@result.ImpressionScore.ToString("F1")</span>
                </div>
                <div class="border-t border-gray-700 pt-4 flex justify-between items-center">
                    <span class="text-gray-300 font-semibold">Turn score</span>
                    <span class="text-yellow-400 font-bold text-lg">+@result.TurnScore</span>
                </div>
            </div>
        }

        @if (_isHost)
        {
            <button @onclick="OnAdvance" disabled="@_advancing"
                    class="w-full py-4 rounded-xl font-bold text-lg bg-yellow-400 text-black hover:bg-yellow-300 transition-all">
                @(_advancing ? "Loading…" : _nextLabel)
            </button>
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="mt-3 text-red-400 text-sm text-center">@_error</p>
            }
        }
        else
        {
            <p class="text-center text-gray-500 text-sm">Waiting for the host to continue…</p>
        }

        <ScoreBoard />
        <LeaveGameButton />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Func<Task<HubResult>> AdvanceTurnFunc { get; set; } = default!;

    private bool _isHost;
    private bool _advancing;
    private string? _error;
    private string _nextLabel = "Next Turn";

    protected override void OnParametersSet()
    {
        _isHost = GameState.State?.Players
            .Any(p => p.Name == GameState.PlayerName && p.IsHost) ?? false;

        var state = GameState.State;
        if (state is null) return;
        var speakerIndex = state.Players.ToList().FindIndex(p => p.Name == state.ActivePlayerName);
        _nextLabel = speakerIndex >= state.Players.Count - 1 ? "See Final Results" : "Next Turn";
    }

    private async Task OnAdvance()
    {
        _advancing = true;
        _error = null;
        var result = await AdvanceTurnFunc();
        if (!result.Success) _error = result.Error;
        _advancing = false;
    }
}
