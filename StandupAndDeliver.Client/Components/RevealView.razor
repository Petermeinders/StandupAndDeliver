@inject GameStateService GameState

<div class="min-h-screen text-white flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md">

        <p class="text-center text-gray-600 text-xs font-mono mb-4">Room: @GameState.State?.RoomCode</p>

        <p class="text-center text-gray-400 text-xs uppercase tracking-widest mb-2">The prompt was…</p>

        <div class="bg-yellow-400 text-black rounded-2xl p-8 mb-8 text-center shadow-lg">
            <p class="text-xl font-bold leading-snug">
                @(GameState.State?.LastTurnResult?.PromptCardText ?? GameState.State?.PromptCardText)
            </p>
        </div>

        @if (_isActiveSpeaker)
        {
            <div class="bg-gray-900 rounded-2xl p-6 text-center">
                <p class="text-gray-400">Others are voting on whether you lied…</p>
                <p class="mt-3 text-sm text-gray-500">
                    @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal votes submitted
                </p>
            </div>
        }
        else if (!_lieVoteSubmitted)
        {
            <div class="bg-gray-900 rounded-2xl p-6 mb-6">
                <p class="text-sm font-semibold text-gray-300 mb-3">Did @GameState.State?.ActivePlayerName lie?</p>
                <div class="flex gap-3">
                    <button @onclick='() => _lied = true'
                            class="flex-1 py-3 rounded-xl font-bold transition-all
                                   @(_lied == true ? "bg-red-500 text-white" : "bg-gray-800 text-gray-400 hover:bg-gray-700")">
                        Lied
                    </button>
                    <button @onclick='() => _lied = false'
                            class="flex-1 py-3 rounded-xl font-bold transition-all
                                   @(_lied == false ? "bg-green-500 text-white" : "bg-gray-800 text-gray-400 hover:bg-gray-700")">
                        Didn't Lie
                    </button>
                </div>
            </div>

            <button @onclick="OnSubmitLieVote"
                    disabled="@(_lied is null || _submitting)"
                    class="w-full py-4 rounded-xl font-bold text-lg transition-all
                           @(_lied is null ? "bg-gray-700 text-gray-500 cursor-not-allowed" : "bg-yellow-400 text-black hover:bg-yellow-300")">
                @(_submitting ? "Submitting…" : "Submit Vote")
            </button>

            <p class="mt-4 text-center text-sm text-gray-600">
                @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal votes submitted
            </p>

            @if (!string.IsNullOrEmpty(_voteError))
            {
                <p class="mt-2 text-red-400 text-sm text-center">@_voteError</p>
            }
        }
        else
        {
            <div class="bg-gray-900 rounded-2xl p-4 text-center mb-4">
                <p class="text-green-400 text-sm font-semibold">Vote submitted!</p>
                <p class="mt-2 text-xs text-gray-500">
                    @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal votes submitted
                </p>
            </div>
        }

        <ScoreBoard />
        <LeaveGameButton />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Func<bool, Task<HubResult>> SubmitLieVoteFunc { get; set; } = default!;

    private bool _isActiveSpeaker;
    private bool? _lied;
    private bool _submitting;
    private bool _lieVoteSubmitted;
    private string? _voteError;

    protected override void OnParametersSet()
    {
        _isActiveSpeaker = GameState.State?.ActivePlayerName == GameState.PlayerName;
    }

    private async Task OnSubmitLieVote()
    {
        if (_lied is null) return;
        _submitting = true;
        _voteError = null;
        var result = await SubmitLieVoteFunc(_lied.Value);
        if (result.Success) _lieVoteSubmitted = true;
        else _voteError = result.Error;
        _submitting = false;
    }
}
