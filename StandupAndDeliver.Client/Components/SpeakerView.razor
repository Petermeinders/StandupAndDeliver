@inject GameStateService GameState
@inject IJSRuntime JS
@inject SettingsService Settings
@implements IAsyncDisposable

<div class="min-h-screen text-white flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md">

        <p class="text-center text-gray-600 text-xs font-mono mb-3">Room: @GameState.State?.RoomCode</p>

        <GameReferenceAccordions HowToPlayDefaultOpen="false" ExampleDefaultOpen="false" />

        @{
            var reactions = GameState.GetActiveReactions();
        }

        <!-- Header -->
        <div class="text-center mb-4">
            <div class="flex items-center justify-center gap-2">
                <span class="text-xs font-semibold uppercase tracking-widest text-yellow-400">Your Turn</span>
                @if (_micActive)
                {
                    <span class="text-xs text-red-400 animate-pulse">🎙 Live</span>
                }
            </div>
            @if (GameState.State!.CardFlipped)
            {
                <div class="mt-2 flex items-center justify-center gap-2">
                    <span class="text-5xl font-mono font-bold @TimerColour">@GameState.SecondsRemaining</span>
                    <span class="text-gray-400 text-sm">@(_paused ? "paused" : "sec")</span>
                </div>
                <p class="mt-2 text-gray-300 text-sm">Deliver your best speech. Make it sound impressive. Everyone is watching.</p>
            }
            else
            {
                <p class="mt-2 text-gray-400 text-sm">Tap your card to reveal your task and start the clock.</p>
            }
        </div>

        <!-- 3D Card — entire card is the clickable element -->
        <div class="card-flip-scene mb-6" @onclick="OnFlip">
            <div class="card-flip-inner @(GameState.State!.CardFlipped ? "flipped" : "")">

                <!-- Front face (visible before flip): electric border card -->
                <div class="card-face card-face-front">
                    <div class="electric-main-border"></div>
                    <div class="electric-glow-1"></div>
                    <div class="electric-glow-2"></div>
                    <div class="electric-overlay-1"></div>
                    <div class="electric-overlay-2"></div>
                    <div class="electric-bg-glow"></div>
                    <div class="electric-content">
                        <p class="text-4xl">🃏</p>
                        <p class="text-yellow-300 font-bold text-lg">@(_flipping ? "Flipping…" : "Tap to Flip")</p>
                        <p class="text-yellow-200 text-xs opacity-60">Timer starts on flip</p>
                    </div>
                </div>

                <!-- Back face (visible after flip): prompt card -->
                <div class="card-face card-face-back">
                    <div class="electric-main-border"></div>
                    <div class="electric-glow-1"></div>
                    <div class="electric-glow-2"></div>
                    <div class="electric-overlay-1"></div>
                    <div class="electric-overlay-2"></div>
                    <div class="electric-bg-glow"></div>
                    <div class="electric-content px-8">
                        @{
                            var cardParts = (GameState.State?.PromptCardText ?? "").Split("|||");
                            var promptText = cardParts[0];
                            var buzzParts = cardParts.Length > 1 ? cardParts[1].Split('|') : null;
                        }
                        <p class="text-xl font-bold text-yellow-300 leading-snug text-center" style="text-shadow: -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000, 2px 2px 0 #000, 0 2px 0 #000, 0 -2px 0 #000, 2px 0 0 #000, -2px 0 0 #000;">
                            @promptText
                        </p>
                        @if (buzzParts is { Length: 3 })
                        {
                            <div class="mt-3 flex flex-wrap gap-1 justify-center">
                                <span class="text-xs text-gray-400 w-full text-center mb-1">Helpful words</span>
                                <span class="bg-black/40 text-yellow-200 text-xs font-mono px-2 py-1 rounded">@buzzParts[0]</span>
                                <span class="bg-black/40 text-yellow-200 text-xs font-mono px-2 py-1 rounded">@buzzParts[1]</span>
                                <span class="bg-black/40 text-yellow-200 text-xs font-mono px-2 py-1 rounded">@buzzParts[2]</span>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>

        @if (GameState.State!.CardFlipped)
        {
            @if (reactions.Count > 0)
            {
                <div class="flex flex-wrap gap-2 justify-center mb-4">
                    @foreach (var r in reactions.TakeLast(6))
                    {
                        <span class="bg-gray-800 rounded-full px-3 py-1 text-sm flex items-center gap-1 animate-bounce">
                            <span>@r.Emoji</span>
                            <span class="text-gray-400 text-xs">@r.PlayerName</span>
                        </span>
                    }
                </div>
            }
            else
            {
                <div class="min-h-8 mb-4"></div>
            }

            @if (!string.IsNullOrWhiteSpace(_localTranscript))
            {
                <div class="bg-gray-900 rounded-2xl p-4 mb-4 text-left">
                    <p class="text-xs text-gray-500 mb-1 flex items-center gap-1">
                        <span class="text-red-400">🎙</span> Others can read this live
                    </p>
                    <p class="text-gray-300 text-sm leading-relaxed">@_localTranscript</p>
                </div>
            }
            else if (_micActive)
            {
                <div class="bg-gray-900 rounded-2xl p-3 mb-4 text-center">
                    <p class="text-xs text-gray-500 animate-pulse">🎙 Listening…</p>
                </div>
            }

            <div class="flex gap-3 mb-3">
                <button @onclick="OnPauseResume"
                        class="flex-1 py-3 rounded-xl font-semibold transition-all
                               @(_paused ? "bg-green-500 text-white hover:bg-green-400" : "bg-gray-700 text-gray-300 hover:bg-gray-600")">
                    @(_paused ? "Resume" : "Pause")
                </button>
                <button @onclick="OnDone" disabled="@_ending"
                        class="flex-1 py-3 rounded-xl font-semibold bg-yellow-400 text-black hover:bg-yellow-300 transition-all">
                    @(_ending ? "…" : "Done")
                </button>
            </div>

            @if (_isHost)
            {
                <button @onclick="OnSkip" disabled="@_skipping"
                        class="w-full py-2 rounded-xl text-sm font-semibold bg-gray-800 text-gray-400 hover:bg-gray-700 transition-all">
                    @(_skipping ? "Skipping…" : "Host: Skip Turn")
                </button>
            }
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="mt-3 text-red-400 text-sm text-center">@_error</p>
        }

        <ScoreBoard />
        <LeaveGameButton />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Func<Task<HubResult>> FlipCardFunc { get; set; } = default!;
    [Parameter, EditorRequired] public Func<Task<HubResult>> EndTurnFunc { get; set; } = default!;
    [Parameter, EditorRequired] public Func<Task<HubResult>> PauseTurnFunc { get; set; } = default!;
    [Parameter, EditorRequired] public Func<Task<HubResult>> ResumeTurnFunc { get; set; } = default!;
    [Parameter, EditorRequired] public Func<Task<HubResult>> SkipTurnFunc { get; set; } = default!;
    [Parameter, EditorRequired] public Func<string, Task> SendTranscriptFunc { get; set; } = default!;

    private bool _isHost;
    private bool _flipping;
    private bool _paused;
    private bool _ending;
    private bool _skipping;
    private string? _error;
    private bool _micActive;
    private string _localTranscript = "";
    private DotNetObjectReference<SpeakerView>? _dotNetRef;

    private string TimerColour => _paused ? "text-gray-400" : GameState.SecondsRemaining switch
    {
        <= 10 => "text-red-400",
        <= 20 => "text-yellow-400",
        _ => "text-white"
    };

    protected override void OnParametersSet()
    {
        _isHost = GameState.State?.Players
            .Any(p => p.Name == GameState.PlayerName && p.IsHost) ?? false;
    }

    private async Task OnFlip()
    {
        _flipping = true;
        _error = null;
        var result = await FlipCardFunc();
        if (result.Success)
            await StartMicAsync();
        else
            _error = result.Error;
        _flipping = false;
    }

    private async Task OnDone()
    {
        await StopMicAsync();
        _ending = true;
        _error = null;
        var result = await EndTurnFunc();
        if (!result.Success) _error = result.Error;
        _ending = false;
    }

    private async Task OnPauseResume()
    {
        _error = null;
        if (_paused)
        {
            var result = await ResumeTurnFunc();
            if (result.Success) _paused = false;
            else _error = result.Error;
        }
        else
        {
            var result = await PauseTurnFunc();
            if (result.Success) _paused = true;
            else _error = result.Error;
        }
    }

    private async Task OnSkip()
    {
        await StopMicAsync();
        _skipping = true;
        _error = null;
        var result = await SkipTurnFunc();
        if (!result.Success) _error = result.Error;
        _skipping = false;
    }

    private async Task StartMicAsync()
    {
        if (!Settings.MicEnabled) return;
        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _micActive = await JS.InvokeAsync<bool>("gameInterop.startSpeechRecognition", _dotNetRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Transcript] mic init failed: {ex.Message}");
            _micActive = false;
        }
    }

    private async Task StopMicAsync()
    {
        if (_micActive)
        {
            await JS.InvokeVoidAsync("gameInterop.stopSpeechRecognition");
            _micActive = false;
        }
    }

    [JSInvokable]
    public async Task OnTranscriptUpdate(string text)
    {
        _localTranscript = text;
        await InvokeAsync(StateHasChanged);
        await SendTranscriptFunc(text);
    }

    public async ValueTask DisposeAsync()
    {
        await StopMicAsync();
        _dotNetRef?.Dispose();
    }
}
