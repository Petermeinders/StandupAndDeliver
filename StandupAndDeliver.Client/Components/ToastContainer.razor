@inject ToastService Toasts
@implements IDisposable

<div class="fixed bottom-4 right-4 flex flex-col gap-2 z-[200] pointer-events-none">
    @foreach (var t in Toasts.Toasts)
    {
        <div @key="t.Id"
             class="flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium pointer-events-auto
                    transition-all animate-slide-in max-w-xs
                    @BgClass(t.Level)">
            <span>@Icon(t.Level)</span>
            <span class="flex-1">@t.Text</span>
            <button @onclick="() => Toasts.Dismiss(t.Id)"
                    class="text-current opacity-60 hover:opacity-100 ml-1 shrink-0">✕</button>
        </div>
    }
</div>

@code {
    protected override void OnInitialized() => Toasts.OnChange += Refresh;
    public void Dispose() => Toasts.OnChange -= Refresh;
    private void Refresh() => InvokeAsync(StateHasChanged);

    private static string BgClass(ToastLevel level) => level switch
    {
        ToastLevel.Success => "bg-green-800 text-green-100 border border-green-600",
        ToastLevel.Warning => "bg-yellow-700 text-yellow-100 border border-yellow-500",
        ToastLevel.Error   => "bg-red-800 text-red-100 border border-red-600",
        _                  => "bg-gray-800 text-gray-100 border border-gray-600",
    };

    private static string Icon(ToastLevel level) => level switch
    {
        ToastLevel.Success => "✓",
        ToastLevel.Warning => "⚠",
        ToastLevel.Error   => "✕",
        _                  => "ℹ",
    };
}
