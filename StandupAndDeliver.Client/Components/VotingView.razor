@inject GameStateService GameState

<div class="min-h-screen bg-gray-950 text-white flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md">

        <p class="text-center text-gray-600 text-xs font-mono mb-6">Room: @GameState.State?.RoomCode</p>

        <p class="text-center text-gray-400 text-sm uppercase tracking-widest mb-1">Now speaking</p>
        <h2 class="text-2xl font-bold text-center mb-1">@GameState.State?.ActivePlayerName</h2>
        <p class="text-center text-gray-500 text-sm mb-6">Rate their delivery before the card is revealed</p>

        @if (_isActiveSpeaker)
        {
            <div class="bg-gray-900 rounded-2xl p-8 text-center">
                <p class="text-gray-400">Others are rating your performance…</p>
                <p class="mt-4 text-sm text-gray-500">
                    @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal ratings submitted
                </p>
            </div>
        }
        else if (_submitted)
        {
            <div class="bg-gray-900 rounded-2xl p-8 text-center">
                <p class="text-green-400 font-semibold mb-2">Rating submitted!</p>
                <p class="text-sm text-gray-500">
                    @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal ratings submitted
                </p>
                <p class="mt-4 text-xs text-gray-600">The prompt card will be revealed once everyone has rated.</p>
            </div>
        }
        else
        {
            <div class="bg-gray-900 rounded-2xl p-6 mb-6">
                <p class="text-sm font-semibold text-gray-300 mb-4">How impressive was that? (1–5)</p>
                <div class="flex gap-2 justify-center">
                    @for (var i = 1; i <= 5; i++)
                    {
                        var score = i;
                        <button @onclick="() => _impressiveness = score"
                                class="w-14 h-14 rounded-xl font-bold text-xl transition-all
                                       @(_impressiveness == score ? "bg-yellow-400 text-black" : "bg-gray-800 text-gray-400 hover:bg-gray-700")">
                            @score
                        </button>
                    }
                </div>
            </div>

            <button @onclick="OnSubmit"
                    disabled="@(_impressiveness is null || _submitting)"
                    class="w-full py-4 rounded-xl font-bold text-lg transition-all
                           @(_impressiveness is null
                               ? "bg-gray-700 text-gray-500 cursor-not-allowed"
                               : "bg-yellow-400 text-black hover:bg-yellow-300")">
                @(_submitting ? "Submitting…" : "Submit Rating")
            </button>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="mt-3 text-red-400 text-sm text-center">@_error</p>
            }

            <p class="mt-4 text-center text-sm text-gray-600">
                @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal ratings submitted
            </p>
        }
        <ScoreBoard />
        <LeaveGameButton />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Func<int, Task<HubResult>> SubmitImpressivenessFunc { get; set; } = default!;

    private int? _impressiveness;
    private bool _submitting;
    private bool _submitted;
    private bool _isActiveSpeaker;
    private string? _error;

    protected override void OnParametersSet()
    {
        _isActiveSpeaker = GameState.State?.ActivePlayerName == GameState.PlayerName;
    }

    private async Task OnSubmit()
    {
        if (_impressiveness is null) return;
        _submitting = true;
        _error = null;
        var result = await SubmitImpressivenessFunc(_impressiveness.Value);
        if (result.Success) _submitted = true;
        else _error = result.Error;
        _submitting = false;
    }
}
