@inject GameStateService GameState

<div class="min-h-screen bg-gray-950 text-white flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md">

        <p class="text-center text-gray-400 text-sm uppercase tracking-widest mb-1">Voting</p>
        <h2 class="text-2xl font-bold text-center mb-1">@GameState.State?.ActivePlayerName</h2>
        <p class="text-center text-gray-500 text-sm mb-6">just delivered their standup</p>

        @if (_isActiveSpeaker)
        {
            <div class="bg-gray-900 rounded-2xl p-8 text-center">
                <p class="text-gray-400">Sit tight — others are voting on your performance.</p>
                <p class="mt-4 text-sm text-gray-500">
                    @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal votes submitted
                </p>
            </div>
        }
        else if (_submitted)
        {
            <div class="bg-gray-900 rounded-2xl p-8 text-center">
                <p class="text-green-400 font-semibold mb-2">Vote submitted!</p>
                <p class="text-sm text-gray-500">
                    @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal votes submitted
                </p>
            </div>
        }
        else
        {
            <div class="bg-gray-900 rounded-2xl p-6 mb-4">
                <p class="text-sm font-semibold text-gray-300 mb-3">Did they lie?</p>
                <div class="flex gap-3">
                    <button @onclick='() => _lied = true'
                            class="flex-1 py-3 rounded-xl font-bold transition-all
                                   @(_lied == true ? "bg-red-500 text-white" : "bg-gray-800 text-gray-400 hover:bg-gray-700")">
                        Lied
                    </button>
                    <button @onclick='() => _lied = false'
                            class="flex-1 py-3 rounded-xl font-bold transition-all
                                   @(_lied == false ? "bg-green-500 text-white" : "bg-gray-800 text-gray-400 hover:bg-gray-700")">
                        Didn't Lie
                    </button>
                </div>
            </div>

            <div class="bg-gray-900 rounded-2xl p-6 mb-6">
                <p class="text-sm font-semibold text-gray-300 mb-3">Impressiveness (1–5)</p>
                <div class="flex gap-2 justify-center">
                    @for (var i = 1; i <= 5; i++)
                    {
                        var score = i;
                        <button @onclick="() => _impressiveness = score"
                                class="w-12 h-12 rounded-xl font-bold text-lg transition-all
                                       @(_impressiveness == score ? "bg-yellow-400 text-black" : "bg-gray-800 text-gray-400 hover:bg-gray-700")">
                            @score
                        </button>
                    }
                </div>
            </div>

            <button @onclick="OnSubmit"
                    disabled="@(_lied is null || _impressiveness is null || _submitting)"
                    class="w-full py-4 rounded-xl font-bold text-lg transition-all
                           @(_lied is null || _impressiveness is null
                               ? "bg-gray-700 text-gray-500 cursor-not-allowed"
                               : "bg-yellow-400 text-black hover:bg-yellow-300")">
                @(_submitting ? "Submitting…" : "Submit Vote")
            </button>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="mt-3 text-red-400 text-sm text-center">@_error</p>
            }

            <p class="mt-4 text-center text-sm text-gray-600">
                @GameState.State?.VotesSubmitted of @GameState.State?.VotesTotal votes submitted
            </p>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Func<bool, int, Task<HubResult>> SubmitVoteFunc { get; set; } = default!;

    private bool? _lied;
    private int? _impressiveness;
    private bool _submitting;
    private bool _submitted;
    private bool _isActiveSpeaker;
    private string? _error;

    protected override void OnParametersSet()
    {
        _isActiveSpeaker = GameState.State?.ActivePlayerName == GameState.PlayerName;
    }

    private async Task OnSubmit()
    {
        if (_lied is null || _impressiveness is null) return;
        _submitting = true;
        _error = null;
        var result = await SubmitVoteFunc(_lied.Value, _impressiveness.Value);
        if (result.Success)
            _submitted = true;
        else
            _error = result.Error;
        _submitting = false;
    }
}
