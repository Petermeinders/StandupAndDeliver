@page "/room"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject GameStateService GameState
@inject GameRegistry Registry
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject SavedSessionService SavedSession
@inject ThemeService Theme
@inject SettingsService Settings
@implements IAsyncDisposable

<PageTitle>Peter's Party Games</PageTitle>

<div class="landing-bg"></div>

@if (_reconnecting)
{
    <div class="fixed top-0 inset-x-0 z-50 bg-yellow-400 text-black text-center text-sm font-semibold py-2">
        Reconnecting…
    </div>
}

@if (_connecting)
{
    <div class="min-h-screen text-white flex items-center justify-center">
        <p class="text-gray-400 text-lg">Connecting…</p>
    </div>
}
else if (_hubClosed)
{
    <div class="min-h-screen text-white flex flex-col items-center justify-center gap-4 p-6">
        <p class="text-yellow-400 text-xl font-bold">Connection Lost</p>
        @if (!string.IsNullOrEmpty(_closedRoomCode))
        {
            <p class="text-gray-400 text-sm">
                Room: <span class="font-mono text-white text-lg">@_closedRoomCode</span>
                &nbsp;·&nbsp; @_closedPlayerName
            </p>
        }
        @if (!string.IsNullOrEmpty(_rejoinError))
        {
            <p class="text-red-400 text-sm text-center">@_rejoinError</p>
        }
        <button @onclick="TryRejoinAsync" disabled="@_rejoining"
                class="px-8 py-3 bg-yellow-400 text-black rounded-xl font-bold hover:bg-yellow-300 transition-all">
            @(_rejoining ? "Reconnecting…" : "Try Reconnect")
        </button>
        <button @onclick="GoHomeAsync"
                class="px-8 py-3 bg-gray-700 text-gray-300 rounded-xl font-semibold hover:bg-gray-600 transition-all">
            Back to Home
        </button>
    </div>
}
else if (!string.IsNullOrEmpty(_fatalError))
{
    <div class="min-h-screen text-white flex flex-col items-center justify-center gap-4">
        <p class="text-red-400 text-lg">@_fatalError</p>
        <button @onclick="GoHomeAsync" class="px-6 py-3 bg-yellow-400 text-black rounded-xl font-bold hover:bg-yellow-300">
            Back to Home
        </button>
    </div>
}
else if (GameState.PlatformState?.Phase == GamePhase.Lobby)
{
    <div @key="GamePhase.Lobby" class="screen-fade">
        <LobbyView OnStart="StateHasChanged" StartGameFunc="StartGame" />
    </div>
}
else if (GameState.PlatformState is { } platform)
{
    var gameCompType = Registry.GetComponent(platform.GameType);
    @if (gameCompType is not null)
    {
        <div @key="@platform.GameType" class="screen-fade">
            <DynamicComponent Type="gameCompType" Parameters="_gameParams" />
        </div>
    }
    else
    {
        <div class="min-h-screen text-white flex items-center justify-center">
            <p class="text-gray-400">Unknown game type: @platform.GameType</p>
        </div>
    }
}
else
{
    <div class="min-h-screen text-white flex items-center justify-center">
        <p class="text-gray-400">Loading…</p>
    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery] public string? Action { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Code { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Game { get; set; }

    private HubConnection? _hub;
    private VisibilityInterop? _visibilityInterop;
    private bool _connecting = true;
    private bool _reconnecting;
    private bool _hubClosed;
    private bool _rejoining;
    private string? _closedRoomCode;
    private string? _closedPlayerName;
    private string? _rejoinError;
    private string? _fatalError;

    private Dictionary<string, object> _gameParams = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Theme.InitializeAsync();
        await Settings.InitializeAsync();

        if (string.IsNullOrEmpty(GameState.PlayerName))
        {
            Nav.NavigateTo("/");
            return;
        }

        _gameParams = new Dictionary<string, object>
        {
            ["GameActionFunc"] = (Func<string, string?, Task<HubResult>>)GameAction
        };

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/gamehub"), options =>
            {
                options.Transports = HttpTransportType.WebSockets;
                options.SkipNegotiation = true;
            })
            .WithAutomaticReconnect([TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10)])
            .Build();

        _hub.Reconnected += async _ =>
        {
            _reconnecting = false;
            if (GameState.PlatformState is not null && GameState.PlayerName is not null)
                await _hub.InvokeAsync<HubResult>("RejoinRoom", GameState.PlatformState.RoomCode, GameState.PlayerName);
            await InvokeAsync(StateHasChanged);
        };

        _hub.Reconnecting += _ =>
        {
            _reconnecting = true;
            return InvokeAsync(StateHasChanged);
        };

        _hub.Closed += _ =>
        {
            _reconnecting = false;
            _hubClosed = true;
            _closedRoomCode = GameState.PlatformState?.RoomCode;
            _closedPlayerName = GameState.PlayerName;
            return InvokeAsync(StateHasChanged);
        };

        _hub.On<GameStateDto>("ReceiveGameState", async state =>
        {
            GameState.UpdatePlatform(state);
            if (state.Phase == GamePhase.GameOver)
                await SavedSession.ClearAsync();
            else if (state.RoomCode is not null && GameState.PlayerName is not null)
                await SavedSession.SaveAsync(state.RoomCode, GameState.PlayerName);
            await InvokeAsync(StateHasChanged);
        });

        _hub.On<string, string>("ReceiveGameSpecificState", (gameType, json) =>
        {
            GameState.UpdateGameState(gameType, json);
            InvokeAsync(StateHasChanged);
        });

        _hub.On<int>("ReceiveTimerTick", seconds =>
        {
            GameState.UpdateTimer(seconds);
            InvokeAsync(StateHasChanged);
        });

        _hub.On<int, int>("ReceiveVoteCount", (submitted, total) =>
        {
            GameState.UpdateVoteCount(submitted, total);
            InvokeAsync(StateHasChanged);
        });

        _hub.On<string, string>("ReceiveReaction", (playerName, emoji) =>
        {
            GameState.AddReaction(playerName, emoji);
            InvokeAsync(StateHasChanged);
        });

        _hub.On<string>("ReceiveTranscript", text =>
        {
            GameState.UpdateTranscript(text);
            InvokeAsync(StateHasChanged);
        });

        _hub.On<GamePhase>("ReceivePhaseChange", phase =>
        {
            if (GameState.PlatformState is not null)
                GameState.UpdatePlatform(GameState.PlatformState with { Phase = phase });
            InvokeAsync(StateHasChanged);
        });

        _hub.On<string>("ReceiveError", error =>
        {
            Console.Error.WriteLine($"[Hub error] {error}");
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hub.StartAsync();

            var gameType = Game ?? GameState.SelectedGameType ?? "standup";

            HubResult result;
            if (Action == "create")
                result = await _hub.InvokeAsync<HubResult>("CreateRoom", GameState.PlayerName, gameType);
            else if (Action == "join" && !string.IsNullOrEmpty(Code))
                result = await _hub.InvokeAsync<HubResult>("JoinRoom", Code, GameState.PlayerName);
            else if (Action == "rejoin" && !string.IsNullOrEmpty(Code))
                result = await _hub.InvokeAsync<HubResult>("RejoinRoom", Code, GameState.PlayerName);
            else
            {
                _fatalError = "Invalid room action.";
                _connecting = false;
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (!result.Success)
            {
                _fatalError = result.Error ?? "Failed to enter room.";
                await SavedSession.ClearAsync();
                _connecting = false;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }
        catch (Exception ex)
        {
            _fatalError = $"Connection failed: {ex.Message}";
            if (Action == "rejoin")
                await SavedSession.ClearAsync();
            _connecting = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _connecting = false;
        _visibilityInterop = new VisibilityInterop(JS, _hub, GameState);
        await _visibilityInterop.RegisterAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<HubResult> StartGame() =>
        _hub is null ? new HubResult(false, "Not connected.") : await _hub.InvokeAsync<HubResult>("StartGame");

    private async Task<HubResult> GameAction(string action, string? payload = null) =>
        _hub is null ? new HubResult(false, "Not connected.") : await _hub.InvokeAsync<HubResult>("GameAction", action, payload);

    private async Task TryRejoinAsync()
    {
        if (_closedRoomCode is null || _closedPlayerName is null) return;
        _rejoining = true;
        _rejoinError = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            if (_hub!.State == HubConnectionState.Disconnected)
                await _hub.StartAsync();
            var result = await _hub.InvokeAsync<HubResult>("RejoinRoom", _closedRoomCode, _closedPlayerName);
            if (result.Success)
            {
                _hubClosed = false;
            }
            else
            {
                _rejoinError = result.Error ?? "Failed to rejoin.";
                await SavedSession.ClearAsync();
            }
        }
        catch (Exception ex)
        {
            _rejoinError = $"Reconnect failed: {ex.Message}";
            await SavedSession.ClearAsync();
        }
        _rejoining = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoHomeAsync()
    {
        await SavedSession.ClearAsync();
        GameState.Clear();
        Nav.NavigateTo("/");
    }

    public async ValueTask DisposeAsync()
    {
        if (_visibilityInterop is not null)
            await _visibilityInterop.DisposeAsync();
        if (_hub is not null)
            await _hub.DisposeAsync();
    }
}
