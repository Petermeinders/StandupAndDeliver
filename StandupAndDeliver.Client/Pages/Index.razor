@page "/"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject GameStateService GameState
@inject HubService Hub
@inject ToastService Toast
@inject GameRegistry Registry
@inject NavigationManager Nav
@inject HttpClient Http
@inject ThemeService Theme
@inject SettingsService Settings
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Fireside Arcade</PageTitle>

<AppHeader @ref="_header" OnSettingsOpen="OpenSettings" />
<SettingsModal @ref="_settingsModal" />

<div class="landing-bg" style="@_bgStyle"></div>
<div class="@(Settings.StickyHeader ? "pt-12" : "") min-h-screen text-white flex flex-col items-center justify-center p-6 relative z-10 overflow-x-hidden">
    <div class="w-full max-w-lg">
        <div class="flex justify-end mb-2">
            <button @onclick="OpenSettings"
                    class="text-gray-500 hover:text-gray-300 transition-all p-2 rounded-lg"
                    title="Settings">
                ⚙
            </button>
        </div>

        <h1 class="text-4xl font-bold text-center mb-1 text-yellow-400">Fireside Arcade</h1>
        <p class="text-center text-gray-500 mb-8 text-sm">Gather around, pick a game</p>

        @if (!string.IsNullOrEmpty(_resumeCode))
        {
            <div class="bg-yellow-400/10 border border-yellow-400/30 rounded-2xl p-5 mb-6">
                <p class="text-xs text-yellow-400 font-semibold uppercase tracking-widest mb-1">Resume Last Session</p>
                <p class="text-gray-300 text-sm mb-3">
                    Room <span class="font-mono font-bold text-white">@_resumeCode</span>
                    &nbsp;·&nbsp; @_resumeName
                </p>
                <button @onclick="OnResume"
                        class="w-full py-3 rounded-xl font-bold bg-yellow-400 text-black hover:bg-yellow-300 transition-all">
                    Rejoin Game
                </button>
            </div>
        }
    </div>

    <div class="relative w-[100vw] left-1/2 -translate-x-1/2 max-w-none mb-2">
        <GamePickerCarousel Games="_gameOptions"
                            @bind-SelectedGameId="_selectedGame"
                            @bind-FocusedGameId="_focusedGameId"
                            LockedToGameId="@_lockedGameId"
                            OnTapped="OnGameTapped" />
    </div>

    <div id="game-content" class="w-full max-w-lg">

        @if (_focusedGame?.SinglePlayer == true && !string.IsNullOrEmpty(_focusedGame.ExternalUrl))
        {
            <div class="bg-gray-900 rounded-2xl p-6 mb-4 border border-emerald-500/20">
                <p class="text-xs text-emerald-400 font-semibold uppercase tracking-widest mb-1">Single player · External game</p>
                <h2 class="text-lg font-semibold text-gray-200 mb-1">@_focusedGame.Name</h2>
                <p class="text-sm text-gray-400 mb-4">@_focusedGame.Tagline</p>
                <a href="@_focusedGame.ExternalUrl"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="block w-full py-3 rounded-xl font-bold text-center bg-emerald-500 text-black hover:bg-emerald-400 transition-all">
                    Play @_focusedGame.Name ↗
                </a>
            </div>
        }

        @if (_focusedGame is { ComingSoon: false })
        {
            <GameHowToPlay GameId="@_focusedGameId" />
        }

        @if (_focusedGame is { ComingSoon: false, SinglePlayer: false })
        {
            <button @onclick="OnPlayGame"
                    disabled="@_playingGame"
                    class="mt-4 w-full py-4 rounded-2xl font-bold text-lg transition-all active:scale-95
                           @(_playingGame
                               ? "bg-gray-700 text-gray-500 cursor-not-allowed"
                               : "bg-yellow-400 text-black hover:bg-yellow-300 shadow-lg shadow-yellow-400/20")">
                @if (_playingGame)
                {
                    <span>Setting up room…</span>
                }
                else if (_roomPlayerCount >= 2)
                {
                    <span>🎮 Play @(_focusedGame?.Name ?? "Game") Together</span>
                }
                else
                {
                    <span>🎮 Play @(_focusedGame?.Name ?? "Game")</span>
                }
            </button>
        }

        <div class="bg-gray-900 rounded-2xl mt-4 overflow-hidden">
            <button @onclick="() => _feedbackOpen = !_feedbackOpen"
                    class="w-full flex items-center justify-between px-6 py-4 text-left">
                <span class="font-semibold text-gray-300">Feedback</span>
                <span class="text-gray-500 text-lg @(_feedbackOpen ? "rotate-180" : "")">▾</span>
            </button>
            @if (_feedbackOpen)
            {
                <div class="px-6 pb-5 border-t border-gray-800 pt-4 space-y-3">
                    <p class="text-xs text-yellow-400 font-semibold uppercase tracking-widest">Early Development Build</p>
                    <p class="text-sm text-gray-400">Please feel free to leave feedback and let me know any problems, recommendations, or features you might like.</p>
                    @if (_feedbackSubmitted)
                    {
                        <p class="text-green-400 text-sm font-semibold">Thanks for your feedback!</p>
                    }
                    else
                    {
                        <textarea @bind="_feedbackText" @bind:event="oninput"
                                  placeholder="Type your feedback here…"
                                  rows="4"
                                  maxlength="2000"
                                  class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-400 resize-none text-sm" />
                        <button @onclick="OnSubmitFeedback"
                                disabled="@(_feedbackSubmitting || string.IsNullOrWhiteSpace(_feedbackText))"
                                class="w-full py-3 rounded-xl font-bold transition-all
                                       @(string.IsNullOrWhiteSpace(_feedbackText)
                                           ? "bg-gray-700 text-gray-500 cursor-not-allowed"
                                           : "bg-yellow-400 text-black hover:bg-yellow-300")">
                            @(_feedbackSubmitting ? "Sending…" : "Submit Feedback")
                        </button>
                        @if (!string.IsNullOrEmpty(_feedbackError))
                        {
                            <p class="text-red-400 text-sm">@_feedbackError</p>
                        }
                    }
                </div>
            }
        </div>

        <PwaInstallNudge />

    </div>
</div>

@code {
    [Parameter, SupplyParameterFromQuery] public string? Error { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Join { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Game { get; set; }

    private List<GamePickerCarousel.GameOption> _gameOptions = [];
    private AppHeader? _header;
    private SettingsModal? _settingsModal;

    private List<GamePickerCarousel.GameOption> BuildGameOptions()
    {
        var options = Registry.Games
            .Select(g => new GamePickerCarousel.GameOption(g.Id, g.Icon, g.Name, g.Tagline, g.ImageUrl))
            .ToList();
        options.Add(new("coming", "✨", "More Soon", "Stay tuned", ComingSoon: true));
        options.Add(new("crypt-sweepers", "💀", "Crypt Sweepers",
            "Every tile a treasure. Every step a death sentence.",
            "/CryptSweepersCover.png",
            SinglePlayer: true,
            ExternalUrl: "https://crypt-sweepers.com",
            SeparatorBefore: true,
            SeparatorLabel: "Single Player"));
        return options;
    }

    private string _selectedGame = "standup";
    private string _focusedGameId = "standup";

    private GamePickerCarousel.GameOption? _focusedGame =>
        _gameOptions.FirstOrDefault(g => g.Id == _focusedGameId);

    private string? _lockedGameId;

    private string _bgStyle =>
        _focusedGame?.ImageUrl is { } img
            ? $"background-image: url('{img}')"
            : "background-image: url('/OfficeBackground.jpg')";

    private bool _feedbackOpen;
    private string _feedbackText = "";
    private bool _feedbackSubmitting;
    private bool _feedbackSubmitted;
    private string? _feedbackError;

    private bool _playingGame;
    private int _roomPlayerCount => GameState.PlatformState?.Players.Count(p => !p.IsBot) ?? 0;

    private bool _themeInitialized;
    private string? _resumeCode;
    private string? _resumeName;

    protected override void OnInitialized()
    {
        _gameOptions = BuildGameOptions();
        Hub.OnGameState += OnGameState;
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Join))
            _lockedGameId = null;
        if (!string.IsNullOrEmpty(Error)) { /* show in header */ }
        if (!string.IsNullOrEmpty(Game) && _gameOptions.Any(g => g.Id == Game))
        {
            _selectedGame = Game;
            _focusedGameId = Game;
        }
        // Propagate selected game to state so header uses it when creating
        GameState.SelectedGameType = _selectedGame;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && _themeInitialized) return;
        _themeInitialized = true;

        await Theme.InitializeAsync();
        await Settings.InitializeAsync();

        try
        {
            var code = await JS.InvokeAsync<string?>("localStorage.getItem", "sad_room");
            var name = await JS.InvokeAsync<string?>("localStorage.getItem", "sad_name");
            if (!string.IsNullOrEmpty(code) && !string.IsNullOrEmpty(name))
            {
                _resumeCode = code;
                _resumeName = name;
            }

            // Pre-populate player name from localStorage
            if (string.IsNullOrEmpty(GameState.PlayerName) && !string.IsNullOrEmpty(name))
                GameState.PlayerName = name;
        }
        catch { }

        // If a join code was passed via URL, look up the room's game type
        if (!string.IsNullOrEmpty(Join))
        {
            try
            {
                var resp = await Http.GetFromJsonAsync<RoomInfoDto>($"/api/rooms/{Join.ToUpperInvariant()}/info");
                if (resp?.GameType is { } gameType)
                {
                    _lockedGameId = gameType;
                    _focusedGameId = gameType;
                    _selectedGame = gameType;
                }
            }
            catch { }
        }

        StateHasChanged();
    }

    private async Task OnGameState(GameStateDto state)
    {
        GameState.UpdatePlatform(state);
        // Auto-navigate to room when game starts
        if (state.Phase != GamePhase.Lobby && state.Phase != GamePhase.GameOver)
            await InvokeAsync(() => Nav.NavigateTo("/room"));
        else
            await InvokeAsync(StateHasChanged);
    }

    private record RoomInfoDto(string GameType);

    private void OnResume()
    {
        if (string.IsNullOrEmpty(_resumeCode) || string.IsNullOrEmpty(_resumeName)) return;
        GameState.PlayerName = _resumeName;
        Nav.NavigateTo($"/room?action=rejoin&code={_resumeCode}");
    }

    private void OnGameTapped(string id)
    {
        GameState.SelectedGameType = id;
        _ = JS.InvokeVoidAsync("gameInterop.peekScroll", "game-content");
    }

    private async Task OnPlayGame()
    {
        // Restore name from localStorage if it was cleared (e.g. after returning from game over)
        if (string.IsNullOrEmpty(GameState.PlayerName))
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "sad_name");
            if (!string.IsNullOrEmpty(saved))
                GameState.PlayerName = saved;
            else
            {
                Toast.Warn("Open 'Join Friends' to set your name first.");
                return;
            }
        }

        _playingGame = true;
        StateHasChanged();

        try
        {
            var gameType = _focusedGameId;

            // If already in a room for this game type, just go to the lobby
            if (GameState.PlatformState is { Phase: GamePhase.Lobby } ps && ps.GameType == gameType)
            {
                Nav.NavigateTo("/room");
                return;
            }

            // Otherwise create a new room for the selected game
            await Hub.EnsureConnectedAsync();
            var result = await Hub.CreateOrJoinAsync(null, GameState.PlayerName, gameType, false);
            if (result.Success)
            {
                await JS.InvokeVoidAsync("gameInterop.playSound", "confirm");
                Nav.NavigateTo("/room");
            }
            else
            {
                Toast.Error(result.Error ?? "Could not create room.");
            }
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _playingGame = false;
        }
    }

    private async Task OnSubmitFeedback()
    {
        if (string.IsNullOrWhiteSpace(_feedbackText)) return;
        _feedbackSubmitting = true;
        _feedbackError = null;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/feedback", new { Message = _feedbackText });
            if (response.IsSuccessStatusCode)
                _feedbackSubmitted = true;
            else
                _feedbackError = "Something went wrong. Please try again.";
        }
        catch
        {
            _feedbackError = "Could not send feedback. Please try again.";
        }
        _feedbackSubmitting = false;
    }

    private void OpenSettings() => _settingsModal?.Open();

    public void Dispose()
    {
        Hub.OnGameState -= OnGameState;
    }
}
