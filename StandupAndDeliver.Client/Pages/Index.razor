@page "/"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject GameStateService GameState
@inject NavigationManager Nav
@inject HttpClient Http
@inject ThemeService Theme
@inject SettingsService Settings
@inject IJSRuntime JS

<PageTitle>Standup & Deliver</PageTitle>

<SettingsModal @ref="_settingsModal" />

<div class="landing-bg"></div>
<div class="min-h-screen text-white flex flex-col items-center justify-center p-6 relative z-10">
    <div class="w-full max-w-md">

        <div class="flex justify-end mb-2">
            <button @onclick="() => _settingsModal!.Open()"
                    class="text-gray-500 hover:text-gray-300 transition-all p-2 rounded-lg"
                    title="Settings">
                ⚙
            </button>
        </div>

        <img src="StandupAndDeliverBanner.jpg" alt="Standup & Deliver" class="w-full rounded-2xl mb-6 shadow-lg" />

        <h1 class="text-4xl font-bold text-center mb-2 text-yellow-400">Standup & Deliver</h1>
        <p class="text-center text-gray-400 mb-8 text-sm">The corporate party game for people who've sat through too many standups</p>

        <GameReferenceAccordions HowToPlayDefaultOpen="true" ExampleDefaultOpen="false" />

        <div class="bg-gray-900 rounded-2xl mb-6 overflow-hidden">
            <button @onclick="() => _storyOpen = !_storyOpen"
                    class="w-full flex items-center justify-between px-6 py-4 text-left">
                <span class="font-semibold text-gray-300">Background</span>
                <span class="text-gray-500 text-lg transition-transform @(_storyOpen ? "rotate-180" : "")">▾</span>
            </button>
            @if (_storyOpen)
            {
                <div class="px-6 pb-5 text-sm text-gray-400 space-y-3 border-t border-gray-800 pt-4">
                    <p>Welcome to <span class="text-gray-300 font-semibold">BusinessCorp</span> — where we are like family.</p>
                    <p>You are employee <span class="text-gray-300 font-mono">100,987</span>. Your cubicle is <span class="text-gray-300 font-mono">C37</span>.</p>
                    <p>Every morning you have a 15-minute <span class="text-yellow-400 font-semibold">"Standup"</span> meeting and give an update to your team about what you did the previous day.</p>
                    <p>Even though you slacked off for 7 hours, you need to convince the team (and boss) that you were very productive. Be sure to use a lot of business lingo to make the work sound important.</p>
                    <p>But if you are caught blatantly lying, it's going to hurt your promotion.</p>
                    <p class="text-gray-500 italic">See you at Standup!</p>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(_resumeCode))
        {
            <div class="bg-yellow-400/10 border border-yellow-400/30 rounded-2xl p-5 mb-4">
                <p class="text-xs text-yellow-400 font-semibold uppercase tracking-widest mb-1">Resume Last Session</p>
                <p class="text-gray-300 text-sm mb-3">
                    Room <span class="font-mono font-bold text-white">@_resumeCode</span>
                    &nbsp;·&nbsp; @_resumeName
                </p>
                <button @onclick="OnResume"
                        class="w-full py-3 rounded-xl font-bold bg-yellow-400 text-black hover:bg-yellow-300 transition-all">
                    Rejoin Game
                </button>
            </div>
        }

        <div class="bg-gray-900 rounded-2xl p-6 mb-4">
            <div class="flex items-baseline justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-300">Create a Room</h2>
                <span class="text-xs text-gray-500">Start here — you'll be the host</span>
            </div>
            <div class="space-y-3">
                <input
                    @bind="_createName"
                    @bind:event="oninput"
                    @onkeydown="OnCreateKeyDown"
                    placeholder="Your name"
                    maxlength="20"
                    class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-400" />
                <button
                    @onclick="OnCreate"
                    disabled="@(_creating || string.IsNullOrWhiteSpace(_createName))"
                    class="w-full py-3 rounded-xl font-bold transition-all
                           @(string.IsNullOrWhiteSpace(_createName)
                               ? "bg-gray-700 text-gray-500 cursor-not-allowed"
                               : "bg-yellow-400 text-black hover:bg-yellow-300")">
                    @(_creating ? "Creating…" : "Create Room")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_createError))
            {
                <p class="mt-3 text-red-400 text-sm">@_createError</p>
            }
        </div>

        <div class="bg-gray-900 rounded-2xl p-6">
            <div class="flex items-baseline justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-300">Join a Room</h2>
                <span class="text-xs text-gray-500">Ask the host for the room code</span>
            </div>
            <div class="space-y-3">
                <input
                    @bind="_joinCode"
                    @bind:event="oninput"
                    @onkeydown="OnJoinKeyDown"
                    placeholder="Room code (e.g. ABCD)"
                    maxlength="4"
                    class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 font-mono uppercase tracking-widest focus:outline-none focus:border-yellow-400" />
                <input
                    @bind="_joinName"
                    @bind:event="oninput"
                    @onkeydown="OnJoinKeyDown"
                    placeholder="Your name"
                    maxlength="20"
                    class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-400" />
                <button
                    @onclick="OnJoin"
                    disabled="@(_joining || string.IsNullOrWhiteSpace(_joinCode) || string.IsNullOrWhiteSpace(_joinName))"
                    class="w-full py-3 rounded-xl font-bold transition-all
                           @(string.IsNullOrWhiteSpace(_joinCode) || string.IsNullOrWhiteSpace(_joinName)
                               ? "bg-gray-700 text-gray-500 cursor-not-allowed"
                               : "bg-gray-600 text-white hover:bg-gray-500")">
                    @(_joining ? "Joining…" : "Join Room")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_joinError))
            {
                <p class="mt-3 text-red-400 text-sm">@_joinError</p>
            }
        </div>

        <div class="bg-gray-900 rounded-2xl mt-4 overflow-hidden">
            <button @onclick="() => _feedbackOpen = !_feedbackOpen"
                    class="w-full flex items-center justify-between px-6 py-4 text-left">
                <span class="font-semibold text-gray-300">Feedback</span>
                <span class="text-gray-500 text-lg @(_feedbackOpen ? "rotate-180" : "")">▾</span>
            </button>
            @if (_feedbackOpen)
            {
                <div class="px-6 pb-5 border-t border-gray-800 pt-4 space-y-3">
                    <p class="text-xs text-yellow-400 font-semibold uppercase tracking-widest">Early Development Build</p>
                    <p class="text-sm text-gray-400">Please feel free to leave feedback and let me know any problems, recommendations, or features you might like.</p>
                    @if (_feedbackSubmitted)
                    {
                        <p class="text-green-400 text-sm font-semibold">Thanks for your feedback! 🙌</p>
                    }
                    else
                    {
                        <textarea @bind="_feedbackText" @bind:event="oninput"
                                  placeholder="Type your feedback here…"
                                  rows="4"
                                  maxlength="2000"
                                  class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-yellow-400 resize-none text-sm" />
                        <button @onclick="OnSubmitFeedback"
                                disabled="@(_feedbackSubmitting || string.IsNullOrWhiteSpace(_feedbackText))"
                                class="w-full py-3 rounded-xl font-bold transition-all
                                       @(string.IsNullOrWhiteSpace(_feedbackText)
                                           ? "bg-gray-700 text-gray-500 cursor-not-allowed"
                                           : "bg-yellow-400 text-black hover:bg-yellow-300")">
                            @(_feedbackSubmitting ? "Sending…" : "Submit Feedback")
                        </button>
                        @if (!string.IsNullOrEmpty(_feedbackError))
                        {
                            <p class="text-red-400 text-sm">@_feedbackError</p>
                        }
                    }
                </div>
            }
        </div>

    </div>
</div>

@code {
    [Parameter, SupplyParameterFromQuery] public string? Error { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Join { get; set; }

    private bool _storyOpen = false;
    private bool _feedbackOpen = false;
    private string _feedbackText = "";
    private bool _feedbackSubmitting;
    private bool _feedbackSubmitted;
    private string? _feedbackError;
    private string _createName = "";
    private string _joinCode = "";
    private string _joinName = "";
    private bool _creating;
    private bool _joining;
    private string? _createError;
    private string? _joinError;

    private bool _themeInitialized;
    private SettingsModal? _settingsModal;
    private string? _resumeCode;
    private string? _resumeName;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Join))
            _joinCode = Join.ToUpperInvariant();
        if (!string.IsNullOrEmpty(Error))
            _joinError = Error;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_themeInitialized)
        {
            _themeInitialized = true;
            await Theme.InitializeAsync();
            await Settings.InitializeAsync();

            // Check for a saved session the player can jump back into
            try
            {
                var code = await JS.InvokeAsync<string?>("localStorage.getItem", "sad_room");
                var name = await JS.InvokeAsync<string?>("localStorage.getItem", "sad_name");
                if (!string.IsNullOrEmpty(code) && !string.IsNullOrEmpty(name))
                {
                    _resumeCode = code;
                    _resumeName = name;
                }
                else
                {
                    _resumeCode = null;
                    _resumeName = null;
                }
            }
            catch { /* localStorage unavailable */ }

            StateHasChanged();
        }
    }

    private void OnResume()
    {
        if (string.IsNullOrEmpty(_resumeCode) || string.IsNullOrEmpty(_resumeName)) return;
        GameState.PlayerName = _resumeName;
        Nav.NavigateTo($"/room?action=rejoin&code={_resumeCode}");
    }

    private async Task OnCreate()
    {
        if (string.IsNullOrWhiteSpace(_createName)) return;
        _creating = true;
        _createError = null;
        GameState.PlayerName = _createName.Trim();
        Nav.NavigateTo($"/room?action=create");
    }

    private async Task OnJoin()
    {
        if (string.IsNullOrWhiteSpace(_joinCode) || string.IsNullOrWhiteSpace(_joinName)) return;
        _joining = true;
        _joinError = null;
        GameState.PlayerName = _joinName.Trim();
        Nav.NavigateTo($"/room?action=join&code={_joinCode.ToUpperInvariant()}");
    }

    private async Task OnCreateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnCreate();
    }

    private async Task OnJoinKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnJoin();
    }

    private async Task OnSubmitFeedback()
    {
        if (string.IsNullOrWhiteSpace(_feedbackText)) return;
        _feedbackSubmitting = true;
        _feedbackError = null;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/feedback", new { Message = _feedbackText });
            if (response.IsSuccessStatusCode)
                _feedbackSubmitted = true;
            else
                _feedbackError = "Something went wrong. Please try again.";
        }
        catch
        {
            _feedbackError = "Could not send feedback. Please try again.";
        }
        _feedbackSubmitting = false;
    }
}
